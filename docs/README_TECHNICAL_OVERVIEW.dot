digraph ReadmeTechnicalOverview {
  graph [
    label="Connector ID - Camera to Connector Intelligence";
    labelloc=t;
    fontsize=28;
    fontname="Arial Bold";
    bgcolor="#111827";
    pad=0.35;
    rankdir=TB;
    ranksep=0.80;
    nodesep=0.72;
    splines=spline;
    outputorder=edgesfirst;
    dpi=220;
    ratio=compress;
  ];

  node [
    shape=box;
    style="rounded,filled";
    fontname="Arial";
    fontsize=14;
    margin="0.18,0.12";
    color="#dbeafe";
    fontcolor="#f8fafc";
    penwidth=2.0;
  ];

  edge [
    fontname="Arial";
    fontsize=11;
    fontcolor="#dbeafe";
    color="#93c5fd";
    arrowsize=0.85;
    penwidth=2.0;
  ];

  capture [
    label="Capture\nmobile camera\nvideo / photo";
    shape=component;
    fillcolor="#2563eb:#1e40af";
    gradientangle=90;
  ];

  detect [
    label="Detect\nconnector boxes\nmulti-instance";
    fillcolor="#0f766e:#115e59";
    gradientangle=90;
  ];

  classify [
    label="Classify\nfamily + polarity\ngender + shape";
    fillcolor="#7c3aed:#5b21b6";
    gradientangle=90;
  ];

  verify [
    label="Verify\ngeometry + specs\n3D candidate check";
    fillcolor="#b45309:#92400e";
    gradientangle=90;
  ];

  decide [
    label="Decide\nconfident result\nor ask for angle";
    shape=diamond;
    fillcolor="#dc2626:#991b1b";
    gradientangle=90;
  ];

  result [
    label="Output\nconnector ID\nconfidence + specs";
    shape=note;
    fillcolor="#16a34a:#166534";
    gradientangle=90;
  ];

  feedback [
    label="Improve\ncloud training\nKaggle / Colab";
    shape=folder;
    fillcolor="#475569:#334155";
    gradientangle=90;
  ];

  training_data [
    label="Learn\nverified crops\nsynthetic renders";
    shape=folder;
    fillcolor="#475569:#334155";
    gradientangle=90;
  ];

  export [
    label="Deploy\nserver fallback\nmobile export";
    shape=component;
    fillcolor="#1d4ed8:#1e3a8a";
    gradientangle=90;
  ];

  { rank=same; detect; training_data; }
  { rank=same; classify; feedback; }
  { rank=same; verify; export; }

  capture -> detect [label="frame"];
  detect -> classify [label="crop"];
  classify -> verify [label="attributes"];
  verify -> decide [label="evidence"];
  decide -> result [label="answer"];
  result -> feedback [label="corrections", style=dashed, color="#86efac"];
  feedback -> training_data [label="label + audit", style=dashed, color="#86efac"];
  training_data -> export [label="cloud bake-off", style=dashed, color="#86efac"];
  export -> detect [label="better models", style=dashed, color="#86efac"];
}
