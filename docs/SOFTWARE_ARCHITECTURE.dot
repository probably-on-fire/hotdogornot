digraph RFConnectorAIArchitecture {
  graph [
    label="Connector ID - RF Connector AI Software Architecture and I/O Map";
    labelloc=t;
    fontsize=28;
    fontname="Arial Bold";
    bgcolor="#f7f9fc";
    pad=0.25;
    rankdir=TB;
    ranksep=0.70;
    nodesep=0.34;
    splines=spline;
    overlap=false;
    compound=true;
    outputorder=edgesfirst;
    concentrate=false;
  ];

  node [
    shape=box;
    style="rounded,filled";
    fontname="Arial";
    fontsize=10.5;
    margin="0.10,0.07";
    color="#2f3b52";
    penwidth=1.5;
    fillcolor="#ffffff";
  ];

  edge [
    fontname="Arial";
    fontsize=9;
    color="#56677a";
    arrowsize=0.7;
    penwidth=1.4;
    constraint=false;
  ];

  // Color key:
  // Blue  = current implemented behavior.
  // Gold  = planned roadmap module.
  // Green = data/spec/artifact store.
  // Red   = decision or confidence gate.
  // Purple = external I/O or deployment boundary.

  // -----------------------------------------------------------------------
  // Top-level roadmap documents.
  // -----------------------------------------------------------------------
  subgraph cluster_docs {
    label="Authoritative Roadmap";
    fontsize=16;
    fontname="Arial Bold";
    color="#8c67aa";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#f4ecfb";

    roadmap [
      label="IMPLEMENTATION_PLAN.md\nproduct mission, target architecture,\naccuracy gates, app/API plan";
      shape=note;
      fillcolor="#efe6ff:#fbf8ff";
      gradientangle=90;
    ];
    tasks [
      label="TASKS.md\nEpic 0..12 backlog\nexecution batches";
      shape=note;
      fillcolor="#efe6ff:#fbf8ff";
      gradientangle=90;
    ];
    repo_audit [
      label="REPO_AUDIT.md\ncurrent behavior + safety baseline";
      shape=note;
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    taxonomy_doc [
      label="CONNECTOR_TAXONOMY.md\nfamilies + attribute heads";
      shape=note;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];

    roadmap -> tasks -> repo_audit -> taxonomy_doc [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // User/client input layer.
  // -----------------------------------------------------------------------
  subgraph cluster_clients {
    label="Client I/O";
    fontsize=16;
    fontname="Arial Bold";
    color="#5d78a6";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#eaf4ff";

    camera [
      label="Camera / Gallery / Video\nJPEG, PNG, WebP, MP4, MOV";
      shape=folder;
      fillcolor="#efe6ff:#fbf8ff";
      gradientangle=90;
    ];
    flutter_mobile [
      label="Flutter Mobile App\nIdentify / Contribute / About\niOS + Android";
      shape=component;
      fillcolor="#cfe6ff:#f8fbff";
      gradientangle=90;
    ];
    flutter_desktop [
      label="Flutter Desktop\nWindows / Linux / macOS\nplanned";
      shape=component;
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    streamlit [
      label="Streamlit Demo + Label UI\nupload, label, review, train";
      shape=component;
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];

    camera -> flutter_mobile -> flutter_desktop -> streamlit [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // API layer.
  // -----------------------------------------------------------------------
  subgraph cluster_api {
    label="FastAPI Boundary";
    fontsize=16;
    fontname="Arial Bold";
    color="#40776c";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#e8f7f3";

    predict [
      label="/predict\ncurrent compatible endpoint\nmultipart image + token";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    predict_video [
      label="/predict-video\nsample frames\nreturn best prediction";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    labeler [
      label="/labeler/*\ntrain, holdout,\nvideo upload routes";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    relay [
      label="Relay App\n/uploads, /model/version,\n/model/latest, weights, labels";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];

    predict -> predict_video -> labeler -> relay [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Shared request preparation.
  // -----------------------------------------------------------------------
  subgraph cluster_preprocess {
    label="Request Preprocessing";
    fontsize=16;
    fontname="Arial Bold";
    color="#7d89a3";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#f0f5fb";

    decode [
      label="OpenCV Decode\nimage bytes -> BGR frame";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    frame_sampler [
      label="Video Frame Sampler\nffmpeg / imageio_ffmpeg\n1 fps, capped frames";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];

    decode -> frame_sampler [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Current preserved production path.
  // -----------------------------------------------------------------------
  subgraph cluster_current {
    label="Current Preserved Inference Path";
    fontsize=16;
    fontname="Arial Bold";
    color="#527aa3";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#edf6ff";

    hough [
      label="Hough Crop Detector\ndetect_connector_crops\n1..N candidates";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    fg_gate [
      label="rembg Foreground Gate\nreject background crops";
      shape=diamond;
      fillcolor="#fce3e3:#fff7f7";
      gradientangle=90;
    ];
    clean_crop [
      label="Optional Clean Crop\nalpha composite on white";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    resnet [
      label="ResNet-18 Classifier\nlinear head + 5x TTA\nflat class output";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    old_json [
      label="Compatible JSON\nimage_width, image_height,\npredictions[class_name,\nconfidence, probabilities, bbox]";
      shape=note;
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];

    hough -> fg_gate -> clean_crop -> resnet -> old_json [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Planned production path.
  // -----------------------------------------------------------------------
  subgraph cluster_planned {
    label="Planned Production Vision Pipeline";
    fontsize=16;
    fontname="Arial Bold";
    color="#be8b00";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#fff7df";

    detector [
      label="Object Detector\nYOLO / RT-DETR / Mobile SSD\nbbox + no-connector";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    segment [
      label="Optional Segmentation\nmask refinement\nmeasurement support";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    measure [
      label="Measurement Assist\nArUco scale, hex, aperture,\nthread pitch, body geometry";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    multihead [
      label="Multi-Head Classifier\nfamily, gender/contact,\npolarity, mount,\norientation, termination";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    confidence [
      label="Confidence + Abstention\nambiguous, need angle,\nneed scale, unsupported";
      shape=diamond;
      fillcolor="#fce3e3:#fff7f7";
      gradientangle=90;
    ];
    rich_json [
      label="Rich Prediction JSON\nold fields preserved +\nstructured detections,\nspecs, warnings, latency";
      shape=note;
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];

    detector -> segment -> measure -> multihead -> confidence -> rich_json [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Specs and taxonomy.
  // -----------------------------------------------------------------------
  subgraph cluster_specs {
    label="Taxonomy and Spec Lookup";
    fontsize=16;
    fontname="Arial Bold";
    color="#5a9b62";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#ecfaed";

    connectors_yaml [
      label="connectors.yaml\nSMA, RP-SMA, 3.5mm,\n2.92mm/K/SMK, 2.4mm,\n1.85mm, 1.0mm, SSMA,\nSMB, SMC, QMA, TNC,\nBNC, MCX, 7/16 DIN, unknown";
      shape=folder;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    taxonomy_loader [
      label="taxonomy.py\nload + validate YAML\nserver-safe import";
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    spec_lookup [
      label="Spec Lookup\nimpedance, frequency,\ncompatibility, visual notes";
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    llm_assist [
      label="Optional LLM/VLM Assistant\nexplain result, query specs,\nrequest another angle";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];

    connectors_yaml -> taxonomy_loader -> spec_lookup -> llm_assist [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Data, training, evaluation.
  // -----------------------------------------------------------------------
  subgraph cluster_data_training {
    label="Data, Training, Evaluation";
    fontsize=16;
    fontname="Arial Bold";
    color="#8c67aa";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#f4ecfb";

    raw_data [
      label="Raw / Reference Data\ntraining/data/videos\ntraining/Images\nreference photos";
      shape=folder;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    labeled_data [
      label="Labeled Data\ntraining/data/labeled/embedder\ncurrent classifier folders";
      shape=folder;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    holdout_data [
      label="Holdout Data\ntraining/data/test_holdout\nnever train on this";
      shape=folder;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    dataset_audit [
      label="Dataset Audit CLI\ncounts, dimensions,\nduplicates, corrupt files,\nmissing taxonomy classes";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    dataset_builder [
      label="YOLO Dataset Builder\nweak boxes if needed,\nsplit metadata, no leakage";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    yolo_dataset [
      label="Standard Dataset\ndatasets/rfconnectors/\nimages, labels,\nattributes.csv, data.yaml";
      shape=folder;
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    detector_train [
      label="Detector Training\nYOLO11n/s, RT-DETR small\nmAP + model card";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    classifier_train [
      label="Multi-Head Training\nResNet baseline, EfficientNet,\nMobileNet/MobileViT options";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    eval_all [
      label="Evaluation Harness\nmAP, attribute accuracy,\nmacro F1, calibration,\nlatency, failure gallery";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    reports [
      label="Reports\nreports/experiments/*\nmetrics, confusion matrices,\nfailure gallery, model cards";
      shape=folder;
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];

    raw_data -> labeled_data -> holdout_data -> dataset_audit -> dataset_builder
      -> yolo_dataset -> detector_train -> classifier_train -> eval_all -> reports [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Deployment/output.
  // -----------------------------------------------------------------------
  subgraph cluster_outputs {
    label="Deployment and User Outputs";
    fontsize=16;
    fontname="Arial Bold";
    color="#6d6aa5";
    penwidth=1.8;
    style="rounded,filled";
    fillcolor="#f0efff";

    server_deploy [
      label="Server Deployment\nsystemd + nginx\nreverse SSH tunnel\nFastAPI fallback";
      shape=component;
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    mobile_exports [
      label="Mobile Exports\nONNX, TFLite/LiteRT,\nCore ML";
      shape=folder;
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    result_card [
      label="App Result Card\nfamily, gender, polarity,\nmount, orientation,\nconfidence, warnings, specs";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];

    server_deploy -> mobile_exports -> result_card [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Legend, kept compact at the bottom.
  // -----------------------------------------------------------------------
  subgraph cluster_legend {
    label="Legend";
    fontsize=16;
    fontname="Arial Bold";
    color="#9aa8ba";
    penwidth=1.4;
    style="rounded,filled";
    fillcolor="#eef3f8";

    legend_current [
      label="Blue: current implemented behavior";
      fillcolor="#d9ecff:#f7fbff";
      gradientangle=90;
    ];
    legend_planned [
      label="Gold: planned roadmap module";
      fillcolor="#fff1cc:#fffaf0";
      gradientangle=90;
    ];
    legend_data [
      label="Green: data/spec/artifact store";
      shape=folder;
      fillcolor="#e5f7e7:#f8fff8";
      gradientangle=90;
    ];
    legend_decision [
      label="Red diamond: decision or confidence gate";
      shape=diamond;
      fillcolor="#fce3e3:#fff7f7";
      gradientangle=90;
    ];
    legend_io [
      label="Purple: external I/O or deployment boundary";
      shape=component;
      fillcolor="#efe6ff:#fbf8ff";
      gradientangle=90;
    ];

    legend_current -> legend_planned -> legend_data -> legend_decision -> legend_io [
      style=invis;
      weight=20;
      constraint=true;
    ];
  }

  // -----------------------------------------------------------------------
  // Main request flow.
  // -----------------------------------------------------------------------
  taxonomy_doc -> camera [
    style=invis;
    weight=50;
    constraint=true;
  ];
  streamlit -> predict [
    style=invis;
    weight=50;
    constraint=true;
  ];
  relay -> decode [
    style=invis;
    weight=50;
    constraint=true;
  ];
  frame_sampler -> hough [
    style=invis;
    weight=50;
    constraint=true;
  ];
  old_json -> detector [
    style=invis;
    weight=50;
    constraint=true;
  ];
  rich_json -> connectors_yaml [
    style=invis;
    weight=50;
    constraint=true;
  ];
  llm_assist -> raw_data [
    style=invis;
    weight=50;
    constraint=true;
  ];
  reports -> server_deploy [
    style=invis;
    weight=50;
    constraint=true;
  ];
  result_card -> legend_current [
    style=invis;
    weight=50;
    constraint=true;
  ];

  roadmap -> tasks [label="implementation batches", color="#8c67aa"];
  tasks -> repo_audit [label="Epic 0", color="#8c67aa"];
  tasks -> taxonomy_doc [label="Epic 1", color="#8c67aa"];

  camera -> flutter_mobile [label="capture", color="#3f79b8"];
  camera -> flutter_desktop [label="future desktop input", color="#b98200", style=dashed];
  flutter_mobile -> predict [label="POST image", color="#3f79b8"];
  flutter_mobile -> predict_video [label="POST video", color="#3f79b8"];
  flutter_desktop -> predict [label="same API", color="#b98200", style=dashed];
  streamlit -> labeler [label="label/review uploads", color="#3f79b8"];

  predict -> decode [label="image bytes", color="#3f79b8"];
  predict_video -> frame_sampler [label="video bytes", color="#3f79b8"];
  frame_sampler -> decode [label="sampled frames", color="#3f79b8"];

  // Current preserved path.
  decode -> hough [label="current path", color="#3f79b8"];
  hough -> fg_gate [label="candidate crops", color="#3f79b8"];
  fg_gate -> clean_crop [label="keep", color="#3f79b8"];
  fg_gate -> old_json [label="reject: predictions=[]", color="#b84646"];
  clean_crop -> resnet [label="RGB crop", color="#3f79b8"];
  resnet -> old_json [label="class + confidence", color="#3f79b8"];
  old_json -> result_card [label="existing fields", color="#3f79b8"];

  // Planned richer path.
  decode -> detector [label="planned detector", color="#b98200", style=dashed];
  detector -> segment [label="bbox / mask", color="#b98200", style=dashed];
  detector -> multihead [label="crop", color="#b98200", style=dashed];
  segment -> measure [label="mask geometry", color="#b98200", style=dashed];
  measure -> multihead [label="scale hints", color="#b98200", style=dashed];
  multihead -> confidence [label="attributes + logits", color="#b98200", style=dashed];
  confidence -> rich_json [label="accepted or abstained", color="#b98200", style=dashed];
  rich_json -> result_card [label="structured UI data", color="#b98200", style=dashed];

  // Taxonomy/spec lookup.
  taxonomy_doc -> connectors_yaml [label="defines", color="#5a9b62"];
  connectors_yaml -> taxonomy_loader [label="load/validate", color="#5a9b62"];
  taxonomy_loader -> spec_lookup [label="spec map", color="#5a9b62"];
  confidence -> spec_lookup [label="family + attributes", color="#5a9b62", style=dashed];
  spec_lookup -> rich_json [label="spec summary", color="#5a9b62", style=dashed];
  llm_assist -> rich_json [label="explanation only", color="#8c67aa", style=dashed];

  // Data feedback and training.
  labeler -> labeled_data [label="training captures", color="#5a9b62"];
  labeler -> holdout_data [label="holdout captures", color="#5a9b62"];
  relay -> raw_data [label="uploads/artifacts", color="#5a9b62"];
  raw_data -> dataset_audit [label="inventory", color="#5a9b62", style=dashed];
  labeled_data -> dataset_audit [label="class counts", color="#5a9b62", style=dashed];
  holdout_data -> dataset_audit [label="holdout counts", color="#5a9b62", style=dashed];
  taxonomy_loader -> dataset_audit [label="missing taxonomy classes", color="#5a9b62", style=dashed];
  dataset_audit -> reports [label="audit report", color="#5a9b62", style=dashed];
  labeled_data -> dataset_builder [label="source folders", color="#b98200", style=dashed];
  taxonomy_loader -> dataset_builder [label="validate labels", color="#5a9b62", style=dashed];
  dataset_builder -> yolo_dataset [label="images + labels + attributes", color="#b98200", style=dashed];
  yolo_dataset -> detector_train [label="detection data", color="#b98200", style=dashed];
  yolo_dataset -> classifier_train [label="attribute data", color="#b98200", style=dashed];
  detector_train -> eval_all [label="detector artifact", color="#b98200", style=dashed];
  classifier_train -> eval_all [label="classifier artifact", color="#b98200", style=dashed];
  holdout_data -> eval_all [label="unseen validation", color="#5a9b62", style=dashed];
  eval_all -> reports [label="metrics + failures", color="#8c67aa", style=dashed];
  eval_all -> server_deploy [label="approved server models", color="#8c67aa", style=dashed];
  eval_all -> mobile_exports [label="approved edge exports", color="#8c67aa", style=dashed];

  // Deployment/output.
  server_deploy -> predict [label="serves fallback/API", color="#8c67aa"];
  mobile_exports -> flutter_mobile [label="future on-device inference", color="#8c67aa", style=dashed];
  result_card -> flutter_mobile [label="display + correction chips", color="#8c67aa"];
}
