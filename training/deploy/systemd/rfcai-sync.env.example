# Copy to /etc/default/rfcai-sync (root:root, 0640)
# Used by rfcai-sync.service.

RFCAI_RELAY_HOST=aired.com
RFCAI_RELAY_USER=rfcai
RFCAI_RELAY_INCOMING=/srv/rfcai/incoming
RFCAI_RELAY_MODEL_DIR=/srv/rfcai/models/connector_classifier
RFCAI_LOCAL_INCOMING=/home/rfcai/incoming
RFCAI_LOCAL_MODEL_DIR=/home/rfcai/training/models/connector_classifier
RFCAI_RELAY_PORT=22
RFCAI_SSH_KEY=/home/rfcai/.ssh/id_ed25519
