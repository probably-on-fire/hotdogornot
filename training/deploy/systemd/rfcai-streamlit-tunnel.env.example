# Copy to /etc/default/rfcai-streamlit-tunnel (root:root, 0640)
# Used by rfcai-streamlit-tunnel.service.

RFCAI_RELAY_HOST=aired.com
RFCAI_RELAY_USER=rfcai
RFCAI_SSH_KEY=/home/rfcai/.ssh/id_ed25519

# Forward local Streamlit port to a port on aired.com that nginx will
# then proxy under /demo/. With sshd's default GatewayPorts=no, the
# remote forward binds to loopback automatically — even if you pass an
# explicit bind, it's ignored. So we just use the bare port here.
RFCAI_LOCAL_PORT=8501
RFCAI_REMOTE_BIND=8502
