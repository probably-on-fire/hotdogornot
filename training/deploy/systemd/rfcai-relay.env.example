# Copy to /etc/default/rfcai-relay (root:root, 0640)
# Then `systemctl daemon-reload && systemctl restart rfcai-relay`.

RFCAI_INCOMING_DIR=/srv/rfcai/incoming
RFCAI_MODEL_DIR=/srv/rfcai/models/connector_classifier
RFCAI_DEVICE_TOKEN=replace-me-with-openssl-rand-hex-32
RFCAI_MAX_UPLOAD_BYTES=104857600
# Port uvicorn binds to (behind nginx). Default 8000 conflicts with many
# common Python web stacks; override here if needed (we use 8001 on aired.com).
RFCAI_RELAY_PORT=8000
