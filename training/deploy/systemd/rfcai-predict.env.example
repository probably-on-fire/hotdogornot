# Copy to /etc/default/rfcai-predict (root:root, 0640)
# Used by rfcai-predict.service.

# Same RFCAI_DEVICE_TOKEN used by the relay so phones authenticate the same way.
RFCAI_DEVICE_TOKEN=replace-with-token-from-aired-com

# Where the trained classifier lives. Production training auto-bumps
# weights.latest.pt + labels.json into this directory.
RFCAI_MODEL_DIR=/home/rfcai/training/models/connector_classifier

# Per-request safeguards
RFCAI_MAX_UPLOAD_BYTES=26214400
RFCAI_MAX_DETECTIONS=4

# Video predict (POST /predict-video) — server samples at this rate
# and caps total frames so a 30s phone clip is the upper bound.
RFCAI_MAX_VIDEO_BYTES=209715200
RFCAI_VIDEO_FPS=1.0
RFCAI_VIDEO_MAX_FRAMES=30

# Foreground pre-filter (rembg). Each Hough-detected crop runs through
# rembg before classification — rejects background-only crops that the
# bias-locked classifier would otherwise label confidently. Set
# RFCAI_FG_FILTER=0 to disable if it's too aggressive in production.
# Defaults tuned to keep all 8 held-out connectors and reject wood /
# noise / solid background scenarios in local benchmark.
RFCAI_FG_FILTER=1
RFCAI_MIN_FG_FRACTION=0.05
RFCAI_MIN_UNIFORM_FG=0.20
RFCAI_LOW_CENTER_RATIO=2.0
RFCAI_HIGH_CENTER_RATIO=5.0
