# Copy to /etc/default/rfcai-streamlit (root:root, 0640)
# Used by rfcai-streamlit.service.

# Where the demo posts uploads. Hit the public TLS endpoint so the demo
# also exercises the same path the AR app will eventually use.
RFCAI_RELAY_URL=https://aired.com/rfcai

# Device token for the relay's POST /uploads endpoint. Same token that's
# in /etc/default/rfcai-relay on aired.com — rotate together if you
# rotate it ever.
RFCAI_DEVICE_TOKEN=replace-with-token-from-aired-com
