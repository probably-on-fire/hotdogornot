[Unit]
Description=RF Connector AI relay (uvicorn FastAPI)
After=network-online.target
Wants=network-online.target
# Prevent crash-loop: max 5 restarts in 60s, otherwise leave service in failed.
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=exec
User=rfcai
Group=rfcai
WorkingDirectory=/opt/rfcai/training
EnvironmentFile=/etc/default/rfcai-relay
# uvicorn binds to 127.0.0.1 by default; put nginx in front for TLS+443.
ExecStart=/opt/rfcai/training/.venv/bin/uvicorn \
    rfconnectorai.server.app:app \
    --host 127.0.0.1 \
    --port ${RFCAI_RELAY_PORT} \
    --workers 2 \
    --proxy-headers \
    --forwarded-allow-ips=127.0.0.1
Restart=on-failure
RestartSec=3

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/srv/rfcai
PrivateTmp=yes
PrivateDevices=yes

[Install]
WantedBy=multi-user.target
